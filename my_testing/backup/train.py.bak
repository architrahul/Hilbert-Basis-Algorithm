    "VALIDATION": VALIDATION,
    "VALIDATION_STOP_FACTOR": VALIDATION_STOP_FACTOR,
    "SAVE_MODEL": SAVE_MODEL,
    "LOSS_TYPE": LOSS_TYPE,
    "INTERPRET": INTERPRET,
    "INTERPRET_ONLY_POSITIVE": INTERPRET_ONLY_POSITIVE,
    "INTERPRET_TOP_K_PERCENT": INTERPRET_TOP_K_PERCENT,
    "initial_lr": initial_lr,
    "constant_lr": constant_lr,
    "lr_type": lr_type,
    "freeze info": info
}

print("\n".join(info))
