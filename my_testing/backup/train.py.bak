    final_output = "\n".join(info)
    f.write(final_output)

print(f" Saved run config with run_id={run_id} in {OUTPUT_DIR}")

# do the class weights
label_counts = Counter(train_df["label"])
total = sum(label_counts.values())

neg_weight = total / (2.0 * label_counts[0])
pos_weight = total / (2.0 * label_counts[1])
class_weights = torch.tensor([neg_weight, pos_weight], dtype=torch.float).to(DEVICE)

# Optimizer and Loss
class FocalLoss(torch.nn.Module):
    def __init__(self, alpha=None, gamma=2.0):

        super(FocalLoss, self).__init__()
        self.alpha = alpha
        self.gamma = gamma

    def forward(self, inputs, targets):
        ce_loss = F.cross_entropy(inputs, targets, reduction='none')
        pt = torch.exp(-ce_loss)  # prob of correct class

        if self.alpha is not None:
            if self.alpha.type() != inputs.data.type():
                self.alpha = self.alpha.type_as(inputs.data)
            at = self.alpha[targets]  # per-sample weight
        else:
            at = 1.0

        loss = at * (1 - pt) ** self.gamma * ce_loss
        return loss.mean()
        
if LOSS_TYPE.lower() == "focal_loss":
    loss_fn = FocalLoss(alpha=class_weights, gamma=2.0)
elif LOSS_TYPE.lower() == "cross_entropy":
    loss_fn = torch.nn.CrossEntropyLoss(weight=class_weights)
else:
    raise ValueError(f"Unsupported loss type: {LOSS_TYPE}")

optimizer = AdamW(filter(lambda p: p.requires_grad, model.parameters()), lr=LR)

if constant_lr or lr_type.lower() == "lrstep":
    lr_scheduler = StepLR(
        optimizer,
        step_size=1,
        gamma=1.0 if constant_lr else 0.1
    )
elif lr_type.lower() == "lindecay" and not constant_lr:
    print(" Using linear decay learning rate scheduler.")
    total_training_steps = MAX_EPOCHS * len(train_loader)
    num_warmup_steps = int(0.1 * total_training_steps)  # 10% warmup

    lr_scheduler = get_scheduler("linear", optimizer=optimizer, num_warmup_steps=num_warmup_steps, num_training_steps=total_training_steps)

elif lr_type.lower() == "lrplateau" and not constant_lr:
    print(" Using ReduceLROnPlateau scheduler.")
    lr_scheduler = ReduceLROnPlateau(optimizer, mode='min', factor=0.3, patience=2)
else:
    print(f" Using {lr_type} scheduler with constant learning rate.")


# === Setup ===
patience = 2
best_auc = 0
best_loss = float('inf')
epochs_no_improve = 0

train_losses = []
val_losses = []
val_aucs = []
val_precisions = []
val_recalls = []
val_f1s = []

# === Training Loop ===
for epoch in range(1, MAX_EPOCHS + 1):
    model.train()
    total_loss = 0
    print(f"\nEpoch {epoch}/{MAX_EPOCHS}")

    for batch in tqdm(train_loader):
        batch = {k: v.to(DEVICE) if isinstance(v, torch.Tensor) else v for k, v in batch.items()}
        outputs = model(input_ids=batch['input_ids'], attention_mask=batch['attention_mask'])
        loss = loss_fn(outputs.logits, batch["labels"])
        loss.backward()
        total_loss += loss.item()
        optimizer.step()
        if lr_type.lower() != "lrplateau" or constant_lr:
            lr_scheduler.step() # type: ignore
        optimizer.zero_grad()

    avg_train_loss = total_loss / len(train_loader)
    print(f"Epoch {epoch} training loss: {avg_train_loss:.4f}")
    train_losses.append(avg_train_loss)

    # === Validation ===
    if VALIDATION:
        model.eval()
        all_logits, all_labels = defaultdict(list), {}
        total_val_loss = 0

        with torch.no_grad():
            for batch in val_loader:
                batch = {k: v.to(DEVICE) if isinstance(v, torch.Tensor) else v for k, v in batch.items()}
                outputs = model(input_ids=batch['input_ids'], attention_mask=batch['attention_mask'])
                logits = outputs.logits

                loss = loss_fn(logits, batch["labels"])
                total_val_loss += loss.item()

                for pid, logit, label in zip(batch['pid'], logits, batch['labels']):
                    all_logits[pid].append(logit.cpu().numpy())
                    all_labels[pid] = label.cpu().item()

        avg_val_loss = total_val_loss / len(val_loader)

        if lr_type.lower() == "lrplateau" and not constant_lr:
            lr_scheduler.step(avg_val_loss) # type: ignore

        pred_labels, true_labels = [], []
        for pid, logit_list in all_logits.items():
            avg_logits = np.mean(logit_list, axis=0)
            pred_labels.append(np.argmax(avg_logits))
            true_labels.append(all_labels[pid])

        val_auc = roc_auc_score(true_labels, pred_labels)
        print("\nValidation Results:")
        print(classification_report(true_labels, pred_labels, digits=4))
        print(f"AUC: {val_auc:.4f}")
        print(f"Validation Loss: {avg_val_loss:.4f}")
        
        precision = precision_score(true_labels, pred_labels)
        recall = recall_score(true_labels, pred_labels)
        f1 = f1_score(true_labels, pred_labels)

        val_losses.append(avg_val_loss)
        val_aucs.append(val_auc)
        val_precisions.append(precision)
        val_recalls.append(recall)
        val_f1s.append(f1)

        # === Early Stopping Logic ===
        if VALIDATION_STOP_FACTOR.lower() == "auc":
            if val_auc > best_auc:
                best_auc = val_auc
                epochs_no_improve = 0
                best_model = copy.deepcopy(model)
                print(" Best model saved based on AUC.")
            else:
                epochs_no_improve += 1
                print(f" No AUC improvement for {epochs_no_improve} epoch(s).")

        elif VALIDATION_STOP_FACTOR.lower() == "loss":
            if avg_val_loss < best_loss:
                best_loss = avg_val_loss
                epochs_no_improve = 0
                best_model = copy.deepcopy(model)
                print(" Best model saved based on validation loss.")
            else:
                epochs_no_improve += 1
                print(f" No validation loss improvement for {epochs_no_improve} epoch(s).")

        else:
            raise ValueError(f"Unsupported validation stop factor: {VALIDATION_STOP_FACTOR}")

        if epochs_no_improve >= patience:
            print(f"\n Early stopping triggered after {patience} epoch(s) with no improvement.")
            break

print(f"\n Training completed. Best validation AUC: {best_auc:.4f}")



# Final Test Evaluation
print("\n Evaluating on test set...")
model_to_eval = best_model if best_model is not None else model

if SAVE_MODEL:
    print(" Saving model...")
    os.makedirs(SAVE_DIR, exist_ok=True)
    model_to_eval.save_pretrained(SAVE_DIR)
    tokenizer.save_pretrained(SAVE_DIR)
    print(f" Model saved to {SAVE_DIR}")

model_to_eval.to(DEVICE) # type: ignore
model_to_eval.eval()
all_logits, all_labels = defaultdict(list), {}
with torch.no_grad():
    for batch in tqdm(test_loader):
        batch = {k: v.to(DEVICE) if isinstance(v, torch.Tensor) else v for k, v in batch.items()}
        logits = model(input_ids=batch['input_ids'], attention_mask=batch['attention_mask']).logits
        for pid, logit, label in zip(batch['pid'], logits, batch['labels']):
            all_logits[pid].append(logit.cpu().numpy())
            all_labels[pid] = label.cpu().item()

pred_labels, true_labels = [], []
for pid, logit_list in all_logits.items():
    avg_logits = np.mean(logit_list, axis=0)
    pred_labels.append(np.argmax(avg_logits))
    true_labels.append(all_labels[pid])

print("\n Test Results:")
print(classification_report(true_labels, pred_labels, digits=4))
print(f"AUC: {roc_auc_score(true_labels, pred_labels):.4f}")

test_precision = precision_score(true_labels, pred_labels)
test_recall = recall_score(true_labels, pred_labels)
test_f1 = f1_score(true_labels, pred_labels)
test_auc = roc_auc_score(true_labels, pred_labels)

# save results to CSV
epochs = list(range(1, len(train_losses) + 1))
metrics_df = pd.DataFrame({
    "epoch": epochs,
    "train_loss": train_losses,
    "val_loss": val_losses,
    "val_auc": val_aucs,
    "val_precision": val_precisions,
    "val_recall": val_recalls,
    "val_f1": val_f1s,
    "phase": "train_val"
})

test_metrics = pd.DataFrame({
    "epoch": ["test"],
    "train_loss": [None],
    "val_loss": [None],
    "val_auc": [test_auc],
    "val_precision": [test_precision],
    "val_recall": [test_recall],
    "val_f1": [test_f1],
    "phase": ["test"]
})

metrics_df = pd.concat([metrics_df, test_metrics], ignore_index=True)
os.makedirs(OUTPUT_DIR, exist_ok=True)
metrics_csv_path = os.path.join(OUTPUT_DIR, "training_metrics.csv")
metrics_df.to_csv(metrics_csv_path, index=False)

# Loss plot
