# Validation metrics plot
plt.figure(figsize=(10,6))
plt.plot(epochs, val_aucs, label='Val AUC')
plt.plot(epochs, val_precisions, label='Val Precision')
plt.plot(epochs, val_recalls, label='Val Recall')
plt.plot(epochs, val_f1s, label='Val F1 Score')

# Add test metric points as red dots
plt.scatter(len(epochs) + 1, test_auc, color='red', label='Test AUC', zorder=5)
plt.scatter(len(epochs) + 1, test_precision, color='red', marker='x', label='Test Precision', zorder=5)
plt.scatter(len(epochs) + 1, test_recall, color='red', marker='^', label='Test Recall', zorder=5)
plt.scatter(len(epochs) + 1, test_f1, color='red', marker='s', label='Test F1', zorder=5)

# Add dashed horizontal lines for test metrics (threshold lines)
plt.axhline(y= float(test_auc), color='red', linestyle='--', alpha=0.4)
plt.axhline(y= float(test_precision), color='red', linestyle='--', alpha=0.4)
plt.axhline(y= float(test_recall), color='red', linestyle='--', alpha=0.4)
plt.axhline(y= float(test_f1), color='red', linestyle='--', alpha=0.4)

plt.xlabel('Epoch')
plt.ylabel('Score')
plt.title('Validation Metrics Over Epochs with Test Results Highlighted')
plt.legend()
plt.grid(True)
plt.savefig(os.path.join(OUTPUT_DIR, "val_metrics_plot_with_test.png"))
plt.close()

if INTERPRET_ONLY_POSITIVE:
    test_notes = test_df[test_df.label == 1]["text"].dropna().tolist()
else:
    test_notes = test_df["text"].dropna().tolist()
# Interpret the model
if (INTERPRET):
    model_to_eval.config.output_attentions = True
    interpret_highlighter(
        model=model_to_eval,
        tokenizer=tokenizer,
        notes=test_notes,
        output_html_path=os.path.join(OUTPUT_DIR, "test_interpretation.html"),
        max_len=512,
        stride=256,
        top_k_percent=INTERPRET_TOP_K_PERCENT
    )

    top_k_list = interpret_dictionary(
        model=model_to_eval,
        tokenizer=tokenizer,
        notes=test_notes,
        top_k_percent=INTERPRET_TOP_K_PERCENT
    )

    top_k_list.to_csv(os.path.join(OUTPUT_DIR, "top_k_interpretation.csv"), index=False)
    print(f" Interpretation complete : {os.path.join(OUTPUT_DIR, 'top_k_interpretation.csv')}")