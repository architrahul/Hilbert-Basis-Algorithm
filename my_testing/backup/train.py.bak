# Tokenizer
tokenizer = AutoTokenizer.from_pretrained(model_name, cache_dir=MODEL_DIR, local_files_only=True)

# Dataset with sliding window
class ClinicalNotesChunkedDataset(Dataset):
    def __init__(self, texts, labels, ids, tokenizer, max_length=MAX_LEN, stride=STRIDE):
        self.samples = []
        
        # Calculate a safe character chunk size based on max_length
        # Use approximate ratio of 3-4 characters per token
        char_per_token = 4
        char_chunk_size = int((max_length - 2) * char_per_token)
        
        for text, label, pid in zip(texts, labels, ids):
            # Process text in chunks that won't exceed token limits
            for i in range(0, len(text), stride):
                # Get a chunk of text
                text_chunk = text[i:i + char_chunk_size]
                
                if len(text_chunk) == 0:
                    continue
                    
                # Tokenize directly with proper handling of special tokens
                encoding = tokenizer(
                    text_chunk,
                    add_special_tokens=True,
                    max_length=max_length,
                    truncation=True,
                    return_tensors='pt'
                )
                
                self.samples.append({
                    'input_ids': encoding['input_ids'][0],
                    'attention_mask': encoding['attention_mask'][0],
                    'label': torch.tensor(label),
                    'pid': pid
                })

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, idx):
        item = self.samples[idx]
        return {
            'input_ids': item['input_ids'],
            'attention_mask': item['attention_mask'],
            'labels': item['label'],
            'pid': item['pid']
        }

# === Padding collate_fn ===
def collate_fn(batch):
    input_ids = [item['input_ids'] for item in batch]
    attention_mask = [item['attention_mask'] for item in batch]
    labels = torch.stack([item['labels'] for item in batch])
    pids = [item['pid'] for item in batch]

    input_ids_padded = pad_sequence(input_ids, batch_first=True, padding_value=tokenizer.pad_token_id)
    attention_mask_padded = pad_sequence(attention_mask, batch_first=True, padding_value=0)

    return {
        'input_ids': input_ids_padded,
        'attention_mask': attention_mask_padded,
        'labels': labels,
        'pid': pids
    }

# Create datasets and loaders
train_dataset = ClinicalNotesChunkedDataset(train_df.text.tolist(), train_df.label.tolist(), train_df.index.tolist(), tokenizer, MAX_LEN, STRIDE)
test_dataset = ClinicalNotesChunkedDataset(test_df.text.tolist(), test_df.label.tolist(), test_df.index.tolist(), tokenizer, MAX_LEN, STRIDE)
if VALIDATION:
    val_dataset = ClinicalNotesChunkedDataset(val_df.text.tolist(), val_df.label.tolist(), val_df.index.tolist(), tokenizer, MAX_LEN, STRIDE)

train_loader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True, collate_fn=collate_fn)
test_loader = DataLoader(test_dataset, batch_size=BATCH_SIZE, collate_fn=collate_fn)
if VALIDATION:
    val_loader = DataLoader(val_dataset, batch_size=BATCH_SIZE, collate_fn=collate_fn)

# load model
model = AutoModelForSequenceClassification.from_pretrained(model_name, cache_dir=MODEL_DIR, num_labels=2, local_files_only=True).to(DEVICE)

def print_trainable_summary(model):
    print("\n Trainable Parameters:")
    total_params = 0
    trainable_params = 0
    frozen_params = 0
    layer_summary = defaultdict(lambda: {'trainable': 0, 'frozen': 0})

    for name, param in model.named_parameters():
        n_params = param.numel()
        total_params += n_params

        # Figure out where this param belongs
        if name.startswith("bert.encoder.layer"):
            layer_id = int(name.split(".")[3])
            key = f"encoder.layer.{layer_id}"
        elif name.startswith("bert.embeddings"):
            key = "bert.embeddings"
        elif name.startswith("bert.pooler"):
            key = "bert.pooler"
        elif name.startswith("classifier"):
            key = "classifier"
        else:
            key = "other"

        if param.requires_grad:
            trainable_params += n_params
            layer_summary[key]['trainable'] += n_params
        else:
            frozen_params += n_params
            layer_summary[key]['frozen'] += n_params

    # info.append layer-wise breakdown
    for key, stats in sorted(layer_summary.items()):
        print(f" - {key:<20} | trainable: {stats['trainable']:,} | frozen: {stats['frozen']:,}")

    print("\n Overall Parameter Counts ")
    print(f"Total Parameters:     {total_params:,}")
    print(f"Trainable Parameters: {trainable_params:,}")
    print(f"Frozen Parameters:    {frozen_params:,}")
    print("\n")

model_info = ""
# Freezing Strategy
if LAST_LAYER_ONLY:
    # Freeze everything
    for param in model.bert.parameters():
        param.requires_grad = False

    # Unfreeze last N encoder layers
    N = 4
    for i in range(12 - N, 12):
        for name, param in model.bert.encoder.layer[i].named_parameters():
            param.requires_grad = True

    # Unfreeze classification head
    for param in model.classifier.parameters():
        param.requires_grad = True

    model_info = f"Last {N} layers and classifier head will be fine-tuned.\n"
    info.append(model_info)
else:
    for param in model.parameters():
        param.requires_grad = True
    model_info = "Full model will be fine-tuned.\n"
    info.append(model_info)

# info.append model summary
